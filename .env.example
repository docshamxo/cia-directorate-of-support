# Copy to .env  ->  python bootstrap.py does this for you
# Paste Discord webhook URLs, then save. Never commit .env.

# REQUIRED for live runs: bot token used to add a checkmark to every successful webhook message.
# Create a bot at https://discord.com/developers/applications , invite it to the
# server with Add Reactions + Read Message History (+ channel access), then paste the token here.
# Webhooks cannot react by themselves. Live runs exit non-zero without this token unless you
# pass --allow-skip-reaction / set CIA_ALLOW_SKIP_REACTION=1 (not recommended).
DISCORD_BOT_TOKEN=

# Public community Discord invite (not committed in config/links.yaml).
DISCORD_INVITE_URL=

# OSEC #application-results channel URL (discord.com/channels/...).
DISCORD_OSEC_APPLICATION_RESULTS_URL=

# Optional: after each post, bot deletes other recent webhook messages in the channel.
# Requires DISCORD_BOT_TOKEN plus Manage Messages + Read Message History.
# CIA_BOT_CHANNEL_PURGE=1
# Or pass: python run_all.py --bot-channel-purge

# DS
WEBHOOK_DS_CHAIN_OF_COMMAND=
WEBHOOK_DS_PUBLIC_INFORMATION=
WEBHOOK_DS_SERVER_REGULATIONS=

# OSEC
WEBHOOK_OSEC_INFORMATION=
WEBHOOK_OSEC_STAFF_DOCUMENTS=
WEBHOOK_OSEC_SPP_INFORMATION=
WEBHOOK_OSEC_OPEN_POSITIONS=

# OTE
WEBHOOK_OTE_COC=
WEBHOOK_OTE_PUBLIC_INFORMATION=
WEBHOOK_OTE_PROGRAM_OVERVIEW=
WEBHOOK_OTE_STAFF_DOCUMENTS=
WEBHOOK_OTE_OPEN_POSITIONS=

# GRS
WEBHOOK_GRS_COC=
WEBHOOK_GRS_INFORMATION=
WEBHOOK_GRS_STAFF_DOCUMENTS=

# ESD
WEBHOOK_ESD_COC=
WEBHOOK_ESD_INFORMATION=
WEBHOOK_ESD_STAFF_DOCUMENTS=

# === FILE FOOTER ===
