# Copy to .env  →  python setup.py does this for you
# Paste Discord webhook URLs, then save. Never commit .env.

# DS
WEBHOOK_DS_CHAIN_OF_COMMAND=
WEBHOOK_DS_PUBLIC_INFORMATION=
WEBHOOK_DS_SERVER_REGULATIONS=

# OSEC
WEBHOOK_OSEC_INFORMATION=
WEBHOOK_OSEC_STAFF_DOCUMENTS=
WEBHOOK_OSEC_SPP_INFORMATION=
WEBHOOK_OSEC_OPEN_POSITIONS=

# OTE
WEBHOOK_OTE_COC=
WEBHOOK_OTE_PUBLIC_INFORMATION=
WEBHOOK_OTE_PROGRAM_OVERVIEW=
WEBHOOK_OTE_STAFF_DOCUMENTS=
WEBHOOK_OTE_OPEN_POSITIONS=

# GRS
WEBHOOK_GRS_COC=
WEBHOOK_GRS_INFORMATION=
WEBHOOK_GRS_STAFF_DOCUMENTS=

# ESD
WEBHOOK_ESD_COC=
WEBHOOK_ESD_INFORMATION=
WEBHOOK_ESD_STAFF_DOCUMENTS=

